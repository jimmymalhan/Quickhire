{
  "name": "quickhire-auto-apply",
  "version": "0.0.1-alpha",
  "description": "Automatic LinkedIn Job Application Platform",
  "main": "src/index.js",
  "bin": {
    "agent": "bin/agent.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "agent": "node bin/agent.js",
    "agent:chief": "bash bin/session-chief-agent.sh",
    "agent:supervisor": "bash bin/supervisor-agent.sh",
    "status": "bash bin/live-progress.sh",
    "monitor:live": "bash bin/live-progress.sh",
    "monitor:orchestration": "bash bin/orchestration-monitor.sh",
    "monitor:tail": "tail -f state/local-agent-runtime/dashboard.status",
    "test": "jest --coverage",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "jest --testPathPattern=tests/e2e",
    "test:coverage": "jest --coverage --coverageReporters=text --coverageReporters=lcov",
    "lint": "eslint src/ tests/ --ext .js",
    "lint:fix": "eslint src/ tests/ --ext .js --fix",
    "format": "prettier --write 'src/**/*.js' 'tests/**/*.js'",
    "format:check": "prettier --check 'src/**/*.js' 'tests/**/*.js'",
    "db:migrate": "node src/database/migrate.js",
    "db:migrate:rollback": "node src/database/migrate.js rollback",
    "db:seed": "node src/database/seed.js",
    "db:reset": "npm run db:migrate:rollback && npm run db:migrate && npm run db:seed",
    "precommit": "npm run lint && npm run test"
  },
  "keywords": [
    "linkedin",
    "job-search",
    "auto-apply",
    "automation"
  ],
  "author": "Quickhire Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "axios": "1.13.6",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.8",
    "passport": "^0.7.0",
    "passport-linkedin-oauth2": "^2.0.0",
    "pg": "^8.11.3",
    "pg-pool": "^3.6.1",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^27.6.3",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "prettier": "^3.2.4",
    "supertest": "^6.3.4"
  }
}
