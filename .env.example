# Quickhire Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env file to Git

# Server
PORT=8000
NODE_ENV=development
LOG_LEVEL=debug

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=quickhire_dev
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your_linkedin_app_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:8000/auth/callback

# JWT
JWT_SECRET=your_jwt_secret_key_minimum_32_chars
JWT_EXPIRY=7d
REFRESH_TOKEN_SECRET=your_refresh_secret_key_minimum_32_chars
REFRESH_TOKEN_EXPIRY=30d

# Frontend
REACT_APP_API_URL=http://localhost:8000
REACT_APP_ENVIRONMENT=development

# Email Service
EMAIL_PROVIDER=gmail
EMAIL_FROM=noreply@quickhire.ai
GMAIL_USER=your_email@gmail.com
GMAIL_PASSWORD=your_app_specific_password

# AWS (Optional, for production)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=quickhire-resumes

# Logging
LOG_FORMAT=json
LOG_TO_FILE=false
LOG_FILE_PATH=./logs

# Feature Flags
ENABLE_AUTO_APPLY=true
ENABLE_ML_MATCHING=false
ENABLE_NOTIFICATIONS=true
ENABLE_MOCK_LINKEDIN_API=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Application Settings
MAX_APPLICATIONS_PER_DAY=50
APPLICATION_RETRY_ATTEMPTS=3
APPLICATION_RETRY_DELAY_MS=5000
MIN_APPLICATION_INTERVAL_SECONDS=60

# Scheduler
CRON_JOB_SCRAPING=0 2 * * * # 2 AM daily
CRON_JOB_PROCESSING=0 * * * * # Hourly
CRON_JOB_NOTIFICATIONS=*/30 * * * * # Every 30 minutes

# Security
CORS_ORIGIN=http://localhost:3000
SESSION_SECRET=your_session_secret_key_here
BCRYPT_ROUNDS=12
ENCRYPTION_KEY=your_encryption_key_here_32_chars

# Monitoring & Observability
SENTRY_DSN=
DATADOG_API_KEY=
PROMETHEUS_PORT=9090

# Debug
DEBUG=quickhire:*
VERBOSE_LOGGING=false
